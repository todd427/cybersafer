# CyberSafer v2 — Environment Configuration
# Copy to .env and fill in your values

# Required
ANTHROPIC_API_KEY=your_api_key_here

# Optional — defaults shown
CYBERS_MODEL=claude-haiku-4-5-20251001
CYBERS_JUDGE_MODEL=claude-haiku-4-5-20251001
CYBERS_PORT=8021
CYBERS_HOST=0.0.0.0
SESSION_TTL_HOURS=2

# Scenario mode override
# observe = all scenarios use read-and-identify format (default)
# chat    = all scenarios use live AI adversary chat
# mixed   = respect type field in each scenario JSON
CYBERS_MODE=observe
